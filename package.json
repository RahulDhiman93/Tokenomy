{
  "name": "tokenomy",
  "version": "0.1.0-alpha.20",
  "description": "Surgical Claude Code hook that transparently trims bloated MCP tool responses and clamps oversized file reads — stop burning tokens on tool chatter.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "tokenomy": "dist/cli/entry.js",
    "tokenomy-hook": "dist/hook/entry.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RahulDhiman93/Tokenomy.git"
  },
  "homepage": "https://github.com/RahulDhiman93/Tokenomy#readme",
  "bugs": {
    "url": "https://github.com/RahulDhiman93/Tokenomy/issues"
  },
  "author": {
    "name": "Rahul Dhiman",
    "url": "https://github.com/RahulDhiman93"
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "scripts": {
    "build": "bash scripts/build.sh",
    "test": "node --import tsx --test tests/unit/*.test.ts tests/integration/*.test.ts",
    "test:perf": "node --import tsx --test tests/perf/*.test.ts",
    "coverage": "c8 --reporter=text --reporter=lcov --reporter=html --reporter=json-summary --include='src/**/*.ts' --exclude='src/**/*.d.ts' node --import tsx --test tests/unit/*.test.ts tests/integration/*.test.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "prepublishOnly": "npm run clean && npm run build && npm test && npm run typecheck"
  },
  "keywords": [
    "claude-code",
    "anthropic",
    "mcp",
    "tokens",
    "cost-reduction",
    "hook",
    "agent",
    "llm",
    "tool-output",
    "cli"
  ],
  "license": "MIT",
  "peerDependencies": {
    "typescript": "^5.6.0",
    "js-tiktoken": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    },
    "js-tiktoken": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "c8": "^10.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.15.0"
  }
}
